{% if block.settings.enabled %}
  <div id="ecs-announcement-top-container-{{ block.id }}"></div>

  <style id="ecs-announcement-styles-{{ block.id }}">
    #ecs-announcement-top-container-{{ block.id }}
    #ecs-announcement-bottom-container-{{ block.id }} {
      box-sizing: border-box;
      line-height: 1.5 !important;
    }
    #ecs-announcement-top-container-{{ block.id }} p,
    #ecs-announcement-bottom-container-{{ block.id }} p {
      margin: 0 !important;
    }
    #ecs-announcement-top-container-{{ block.id }} strong,
    #ecs-announcement-bottom-container-{{ block.id }} strong,
    #ecs-announcement-top-container-{{ block.id }} b,
    #ecs-announcement-bottom-container-{{ block.id }} b,
    #ecs-announcement-top-container-{{ block.id }} span,
    #ecs-announcement-bottom-container-{{ block.id }} span {
      font-weight: 800;
    }
    #ecs-announcement-top-container-{{ block.id }} {
      width: 100%;
      position: relative;
      background-color: transparent;
      z-index: 100;
    }
    #ecs-announcement-top-container-{{ block.id }}.ecs-sticky-top-{{ block.id }} {
      position: sticky;
      top: 0;
    }
    .ecs-sticky-transition-{{ block.id }} {
      transition: transform 0.3s ease-in-out !important;
    }
    #ecs-announcement-top-container-{{ block.id }} .ecs-nav-btn {
      padding: 4px !important;
    }
    #ecs-announcement-top-container-{{ block.id }} .ecs-nav-btn svg {
      width: 1.9rem !important;
      height: 1.9rem !important;
    }
    #ecs-announcement-top-container-{{ block.id }} .announcement-icon-svg-wrapper {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: inherit;
    }
    #ecs-announcement-top-container-{{ block.id }} .announcement-icon-svg-wrapper svg {
      width: 100% !important;       
      height: 100% !important;     
      max-width: 100% !important;
      max-height: 100% !important;
      display: block;
    }
    /* Fill-based icons (Instagram, Font Awesome etc) */
    #ecs-announcement-top-container-{{ block.id }} .announcement-icon-svg-wrapper.ecs-icon-fill svg,
    .announcement-icon-svg-wrapper.ecs-icon-fill svg path,
    .announcement-icon-svg-wrapper.ecs-icon-fill svg circle,
    .announcement-icon-svg-wrapper.ecs-icon-fill svg rect,
    .announcement-icon-svg-wrapper.ecs-icon-fill svg polygon,
    .announcement-icon-svg-wrapper.ecs-icon-fill svg ellipse,
    .announcement-icon-svg-wrapper.ecs-icon-fill svg g {
      fill: currentColor !important;
      stroke: none !important;
    }
    /* Stroke-based icons (Feather, Heroicons etc) */
    #ecs-announcement-top-container-{{ block.id }} .announcement-icon-svg-wrapper.ecs-icon-stroke svg,
    .announcement-icon-svg-wrapper.ecs-icon-stroke svg path,
    .announcement-icon-svg-wrapper.ecs-icon-stroke svg circle,
    .announcement-icon-svg-wrapper.ecs-icon-stroke svg rect,
    .announcement-icon-svg-wrapper.ecs-icon-stroke svg polygon,
    .announcement-icon-svg-wrapper.ecs-icon-stroke svg ellipse,
    .announcement-icon-svg-wrapper.ecs-icon-stroke svg line,
    .announcement-icon-svg-wrapper.ecs-icon-stroke svg polyline {
      stroke: currentColor !important;
      fill: none !important;
    }

  </style>

  <script>
    (function() {
      const topContainer = document.getElementById('ecs-announcement-top-container-{{ block.id }}');
      const styleTag = document.getElementById('ecs-announcement-styles-{{ block.id }}');
      const blockId = '{{ block.id }}';
      const shopDomain = Shopify.shop;
      {% comment %} const api = "http://localhost:4000/api/" {% endcomment %}

      const api = "https://ecsannouncement-backend.ecodesoft.net/api/"
      const apiUrl = `${api}announcement/public/${shopDomain}`;

      const assetImages = {
        '/holiday_pink_pattern.png': {{ 'holiday_pink_pattern.png' | asset_url | json }},
        '/sunset_orange.png': {{ 'sunset_orange.png' | asset_url | json }},
        '/modern_abstract_pattern.png': {{ 'modern_abstract_pattern.png' | asset_url | json }},
        '/winter_snowflake_pattern.png': {{ 'winter_snowflake_pattern.png' | asset_url | json }},
        '/midnight_galaxy_pattern.png': {{ 'midnight_galaxy_pattern.png' | asset_url | json }},
        '/lavender_floral_pattern.png': {{ 'lavender_floral_pattern.png' | asset_url | json }},
        '/arctic_frost_crystal.png': {{ 'arctic_frost_crystal.png' | asset_url | json }},
        '/royal_gold.png': {{ 'royal_gold.png' | asset_url | json }},
      };

      const resolveImageUrl = (imgPath) => {
        if (!imgPath) return '';
        if (imgPath.startsWith('data:')) return imgPath;
        if (imgPath.startsWith('http://') || imgPath.startsWith('https://')) return imgPath;
        if (assetImages[imgPath]) return assetImages[imgPath];
        const filename = imgPath.split('/').pop();
        if (assetImages['/' + filename]) return assetImages['/' + filename];
        return imgPath;
      };

      const pageType = {{ request.page_type | json }};
      
      const shouldDisplayOnPage = (pageDisplayArray) => {
        if (!pageDisplayArray || pageDisplayArray.length === 0) return false;
        if (pageDisplayArray.includes("all")) return true;
        if (pageDisplayArray.includes("home") && pageType === "index") return true;
        if (pageDisplayArray.includes("products") && pageType === "product") return true;
        if (pageDisplayArray.includes("catalog") && (pageType === "collection" || pageType === "list-collections")) return true;
        if (pageDisplayArray.includes("contact") && (pageType === "page" || window.location.pathname.includes('contact'))) return true;
        return false;
      };

      const getBackgroundStyle = (formData) => {
        if (formData.background_type === "image") {
          const bgImg = resolveImageUrl(formData.background_image);
          return `background-image: url(${bgImg}); background-repeat: repeat; background-size: cover; background-position: center center; background-color: ${formData.background_color || "transparent"};`;
        }
        if (formData.background_type === "single") {
          return `background-color: ${formData.background_color || '#fce1d0'};`;
        }
        if (formData.background_type === "gradient") {
          return `background: linear-gradient(90deg, ${formData.gradient_colors?.[0] || "#ff7e5f"}, ${formData.gradient_colors?.[1] || "#feb47b"});`;
        }
        return `background-color: #fce1d0;`;
      };

      // Render Icon
     function renderIcon(icon) {
        if (!icon || typeof icon !== 'string') return null;

        /* ── base64-encoded SVG ─────────────────────────────────── */
        if (icon.startsWith('data:image/svg+xml;base64,')) {
          try {
            const decoded = atob(icon.split(',')[1]);
            return { rawSvg: decoded };
          } catch(e) { return null; }
        }

        /* ── raw SVG string ─────────────────────────────────────── */
        if (icon.startsWith('<svg') || icon.includes('<svg ')) {
          return { rawSvg: icon };
        }

        /* ── raster data URL or http(s) URL → mask fallback ─────── */
        if (icon.startsWith('data:image/') || icon.startsWith('http://') || icon.startsWith('https://') || icon.startsWith('/')) {
          return { maskUrl: icon };
        }

        `<div class="announcement-icon-img-wrapper" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;"><img src="${icon}" alt="Icon" style="width: 100%; height: 100%; object-fit: contain;"></div>`;
      }

      /* ══════════════════════════════════════════════════════════════
         buildIconHtml
         Takes the result of renderIcon() + iconColor and produces
         the final HTML string for the icon slot.
         ══════════════════════════════════════════════════════════════ */
     function buildIconHtml(iconResult, iconColor) {
      if (!iconResult) {
        return `
          <div class="announcement-icon-svg-wrapper ecs-icon-stroke" style="color:${iconColor};">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="14.31" y1="8"  x2="20.05" y2="17.94"></line>
              <line x1="9.69"  y1="8"  x2="21.17" y2="8"></line>
              <line x1="7.38"  y1="12" x2="13.12" y2="2.06"></line>
              <line x1="9.69"  y1="16" x2="3.95"  y2="6.06"></line>
              <line x1="14.31" y1="16" x2="2.83"  y2="16"></line>
              <line x1="16.62" y1="12" x2="10.88" y2="21.94"></line>
            </svg>
          </div>`;
      }

        if (iconResult.maskUrl) {
          const url = resolveImageUrl(iconResult.maskUrl);
          // blob: and data: URLs work as <img> src but NOT as CSS mask-image url().
          // Only use the CSS-mask path for real HTTP/HTTPS asset URLs.
          if (url.startsWith('blob:') || url.startsWith('data:')) {
            return `<img src="${url}" alt="Icon" style="width:100%;height:100%;object-fit:contain;display:block;" />`;
          }
          return `
            <div style="
              width:100%; height:100%;
              background-color:${iconColor};
              mask-image:url('${url}');
              -webkit-mask-image:url('${url}');
              mask-size:contain; -webkit-mask-size:contain;
              mask-repeat:no-repeat; -webkit-mask-repeat:no-repeat;
              mask-position:center; -webkit-mask-position:center;
            "></div>`;
        }

        if (iconResult.rawSvg) {
          let svg = iconResult.rawSvg.trim();

          // ── Unwrap accidental double <svg> wrapper ────────────────────────
          const doubleWrapMatch = svg.match(/^<svg[^>]*>\s*(<svg[\s\S]*<\/svg>)\s*<\/svg>$/i);
          if (doubleWrapMatch) {
            svg = doubleWrapMatch[1].trim();
          }

          // ── Detect stroke vs fill based SVG ──────────────────────────────
          const isStrokeBased = (
            /stroke-linecap/i.test(svg) ||
            /stroke-linejoin/i.test(svg) ||
            /stroke-width/i.test(svg)    ||
            /stroke="currentColor"/i.test(svg)
          ) && (
            /fill="none"/i.test(svg) ||
            !/<(path|circle|rect|polygon|polyline|ellipse)[^>]*fill=/i.test(svg)
          );

          let cleanedSvg;

          if (isStrokeBased) {
            cleanedSvg = svg
              .replace(/\bstroke="[^"]*"/g, 'stroke="currentColor"')
              .replace(/(<svg\b[^>]*)\s+width="[^"]*"/gi, '$1')
              .replace(/(<svg\b[^>]*)\s+height="[^"]*"/gi, '$1')
              .replace(/(<svg\b[^>]*)\s+style="[^"]*"/gi, '$1')
              .replace(/(<svg\b[^>]*?)(\s+fill="[^"]*")?([^>]*>)/,
                (m, pre, ef, post) => pre + ' fill="none"' + post)
              .replace(/<(path|circle|rect|polygon|polyline|line|ellipse)\b([^>]*?)(?:\s*\/?>)/gi,
                (match, tag, attrs) => {
                  if (!/stroke=/.test(attrs)) attrs += ' stroke="currentColor"';
                  if (!/fill=/.test(attrs))   attrs += ' fill="none"';
                  const isSelfClosing = match.trim().endsWith('/>');
                  return `<${tag}${attrs}${isSelfClosing ? ' />' : '>'}`;
                });

            return `<div class="announcement-icon-svg-wrapper ecs-icon-stroke" style="color:${iconColor};">${cleanedSvg}</div>`;

          } else {
            // FILL-based SVG (Instagram etc)
            const svgTagMatch  = svg.match(/^<svg\b[^>]*>/i);
            const svgTailMatch = svg.match(/<\/svg>\s*$/i);
            const inner = svg
              .replace(/^<svg\b[^>]*>/i, '')
              .replace(/<\/svg>\s*$/i, '');

            const cleanedInner = inner
              .replace(/\s+fill="[^"]*"/gi, '')
              .replace(/\s+stroke="[^"]*"/gi, '')
              .replace(/\s+fill-rule="[^"]*"/gi, '')
              .replace(/\s+clip-rule="[^"]*"/gi, '')
              // Strip dimensions from any nested <svg> tags inside inner content
              .replace(/(<svg\b[^>]*)\s+width="[^"]*"/gi, '$1')
              .replace(/(<svg\b[^>]*)\s+height="[^"]*"/gi, '$1')
              .replace(/(<svg\b[^>]*)\s+style="[^"]*"/gi, '$1')
              .replace(/(\S)\s+width="[^"]*"/gi, '$1')
              .replace(/(\S)\s+height="[^"]*"/gi, '$1')
              .replace(/\s+style="[^"]*"/gi, '');

            const cleanedSvgTag = (svgTagMatch ? svgTagMatch[0] : '<svg>')
              .replace(/\s+fill="[^"]*"/gi, '')
              .replace(/\s+stroke="[^"]*"/gi, '')
              .replace(/(<svg\b[^>]*)\s+width="[^"]*"/gi, '$1')
              .replace(/(<svg\b[^>]*)\s+height="[^"]*"/gi, '$1')
              .replace(/(\S)\s+width="[^"]*"/gi, '$1')
              .replace(/(\S)\s+height="[^"]*"/gi, '$1')
              .replace(/\s+style="[^"]*"/gi, '');

            cleanedSvg = `${cleanedSvgTag}${cleanedInner}${svgTailMatch ? svgTailMatch[0] : '</svg>'}`;

            return `<div class="announcement-icon-svg-wrapper ecs-icon-fill" style="color:${iconColor};">${cleanedSvg}</div>`;
          }
        }

        return '';
      }

      const createAnnouncementContent = (formData, data) => {
        const current_cta_type = (data && typeof data.cta_type !== 'undefined') ? data.cta_type : formData.cta_type;
        const current_cta_link = (data && typeof data.cta_link !== 'undefined') ? data.cta_link : formData.cta_link || '#';
        const item_type = (data && typeof data.announcement_type !== 'undefined') ? data.announcement_type : formData.announcement_type;
        
        let wrapperTag = 'div';
        let wrapperProps = '';
        const isClickableBar = current_cta_type === "clickable_bar" && current_cta_link && current_cta_link.trim() !== "";
        if (isClickableBar) {
          wrapperTag = 'a';
          wrapperProps = `href="${current_cta_link}" target="_blank"`;
        }
        
        let iconHtml = '';
        const iconColor = (data && data.icon_color) || formData.icon_color || '#000';
        if (item_type !== "running") {
           const rawIcon    = (data && data.icon) || formData.icon || null;
           const iconResult = renderIcon(rawIcon);
           iconHtml         = buildIconHtml(iconResult, iconColor);
         }

        let ctaBtnHtml = '';
        if (item_type !== "running" && current_cta_type === "button") {
          const buttonBorderStyle = formData.button_border_style || "solid";
          const buttonBorderWidth = (buttonBorderStyle && buttonBorderStyle !== "none") ? "3px" : "0px";
          ctaBtnHtml = `
            <div style="margin-left: var(--b-gap); flex-shrink: 0; z-index: 2;">
              <a href="${current_cta_link}" target="_blank" style="
                display: inline-block;
                background-color: ${formData.button_background_color || '#55c521'};
                color: ${formData.button_text_color || '#ffffff'};
                text-decoration: none;
                border-radius: 6px;
                font-size: var(--b-btn-font);
                padding: var(--b-btn-px);
                border: ${buttonBorderWidth} ${buttonBorderStyle} ${formData.button_border_color || '#9dfc1f'};
                cursor: pointer; white-space: nowrap; overflow-wrap: normal;
              ">${data.cta_text || formData.cta_text || "Shop now!"}</a>
            </div>
          `;
        }

          return `
          <${wrapperTag} ${wrapperProps} style="
            text-decoration: none; color: inherit; display: flex; align-items: center; ${formData.announcement_type === 'multiple' && current_cta_type === "button" ? '' : 'flex-direction: var(--b-fd);'}; ${formData.announcement_type === "simple" ? "flex-direction: var(--b-simple-announcement);": ""};
            gap: var(--b-gap); flex-shrink: 1; padding: 0 var(--b-px); 
            min-width: 0;
            white-space: var(--b-whitespace, nowrap); cursor: ${isClickableBar ? 'pointer' : 'default'};
          ">
            ${item_type !== "running" ? `
              <div style="width: var(--b-icon-size); height: var(--b-icon-size); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: ${iconColor};">
                ${iconHtml}
              </div>
            ` : ''}
             {% comment %} simple announcement padding {% endcomment %}
            <div style="display: flex; ${formData.announcement_type === "multiple" ? 'flex-direction: var(--b-fd)' : ""};">
              <div style="display: flex; flex-direction: column; align-items: flex-start; flex-shrink: 1; min-width: 0; max-width: 100%; padding: 5px 0px; overflow-wrap: break-word;"> 
                <div style="font-size: var(--b-title-size); color: ${formData.title_color || '#000'}; font-weight: 400; line-height: 1.1;overflow: hidden; text-overflow: ellipsis; max-width: 100%; width: max-content;">
                  <span style="display: inline;">${data.title || "Announcement"}</span>
                </div>
                 <div style="font-size: var(--b-sub-size); color: ${formData.subheading_color || '#888'}; font-weight: 500; margin-top: 1px; line-height: 1.1;width: 100%;">
                    <span style="display: inline;">${data.subheading}</span>
                  </div>
                {% comment %} ${(formData.announcement_type !== "running" && data.subheading) ? `
                  <div style="font-size: var(--b-sub-size); color: ${formData.subheading_color || '#888'}; font-weight: 500; margin-top: 1px; line-height: 1.1;width: 100%;">
                    <span style="display: inline;">${data.subheading}</span>
                  </div>
                ` : ''} {% endcomment %}
              </div>
               ${ctaBtnHtml}
            </div>
          </${wrapperTag}>
        `;
      };

      const createBarDOM = (formData, index) => {
        const items = formData.announcement_type === "multiple" && (formData.announcements || []).length > 0
          ? formData.announcements : [formData];
        
        const outerDiv = document.createElement("div");
        outerDiv.id = `ecs-b-${blockId}-${index}`;
        
        const tSize = formData.title_size || 14;
        const bSize = formData.button_font_size || 14;
        const tSizeM = Math.min(14, Math.max(11, tSize - 4));
        const bSizeM = Math.max(10, bSize - 2);

        const subSize = formData.subheading_size || 12;
        const subSizeM = Math.max(10, subSize - 2);

        const bPx = formData.announcement_type === "multiple" ? 40 : 32;
        const bPxM = formData.announcement_type === "multiple" ? 11 : 8;

        styleTag.innerHTML += `
          #ecs-b-${blockId}-${index} {
            width: 100%; display: flex; justify-content: center; align-items: center;
            overflow: hidden;
            --b-title-size: ${tSize}px;
            --b-sub-size: ${subSize}px;
            --b-btn-font: ${bSize}px;
            --b-icon-size: 35px;
            --b-gap: 12px;
            --b-px: ${bPx}px;
            --b-btn-px: 4px 12px;
            --b-whitespace: nowrap;
          }
          @media (max-width: 768px) {
            #ecs-b-${blockId}-${index} {
              --b-title-size: ${tSizeM}px;
              --b-sub-size: ${subSizeM}px;
              --b-btn-font: ${bSizeM}px;
              --b-icon-size: 38px;
              --b-gap: 8px;
              --b-px: ${Math.max(14, bPxM)}px;
              --b-btn-px: 2px 8px;
              margin-left: 4px;
            }
          }
         
          @media (max-width: 480px) {
            #ecs-b-${blockId}-${index} {
              --b-title-size: 10.8px;
              --b-sub-size: 10.8px;
              --b-btn-font: 10.8px;
              --b-icon-size: 26px;
              --b-gap: 8px;
              {% comment %} --b-px: ${bPxM}px; {% endcomment %}
              --b-btn-px: 2px 6px;
              --b-inner-py: 4px;
              --b-whitespace: normal;
              --b-fd: column
            }
          }
          @media (max-width: 576px) {
           #ecs-b-${blockId}-${index} {
              --b-title-size: 10.8px;
              --b-sub-size: 10.8px;
              --b-btn-font: 10.8px;
            }
          }
          @media (max-width: 320px) {
          #ecs-b-${blockId}-${index} {
              --b-gap: 4px;
              ---b-icon-size: 22px;

            }
          }
        `;

        const innerDiv = document.createElement("div");
        innerDiv.id = `announcement-running-btn-${index}`;

         styleTag.innerHTML += `
          @media (max-width: 480px) {
            #announcement-running-btn-${index} {
              flex-direction: column;
            }
          }
        `;

        innerDiv.style.cssText = `
          width: 100%; display: flex; align-items: center; justify-content: space-between;
          position: relative; overflow: hidden; padding: var(--b-inner-py, 4px) 0;
          transition: width 0.4s ease-in-out;
          ${getBackgroundStyle(formData)}
        `;

        const contentBox = document.createElement("div");

        contentBox.id = `content-box-${index}`;

        styleTag.innerHTML += `
          @media (max-width: 480px) {
            #content-box-${blockId}-${index} {
              position: unset !important;
            }
          }
        `
        contentBox.style.cssText = `display: flex; align-items: center; overflow: hidden; flex-grow: 1; height: 100%; position: relative;`;

        if (formData.announcement_type === "running") {
          const animId = `marquee-anim-${blockId}-${index}`;
          const duration = (formData.marquee_speed || 20) * 3;
          const direction = formData.marquee_direction === "left" ? "normal" : "reverse";
          
          styleTag.innerHTML += `
            @keyframes ${animId} {
              0% { transform: translateX(0); }
              100% { transform: translateX(-50%); }
            }
          `;

          const trackDiv = document.createElement("div");
          trackDiv.style.cssText = `
            display: flex; width: max-content; 
            animation: ${animId} ${duration}s linear infinite ${direction};
            padding-top: 8px;
            padding-bottom: 8px;
          `;

          let repeatedItemsHtml = '';
          items.forEach((ann) => {
            repeatedItemsHtml += createAnnouncementContent(formData, ann);
          });
          
          let fullTrackHtml = '';
          for(let i=0; i<20; i++) {
             fullTrackHtml += repeatedItemsHtml;
          }
          trackDiv.innerHTML = fullTrackHtml;
          contentBox.appendChild(trackDiv);
          innerDiv.appendChild(contentBox);

          if (formData.cta_type === "button") {
            const btnDiv = document.createElement("div");
            btnDiv.style.cssText = `padding: 0 16px; flex-shrink: 0; z-index: 2;`;
            const buttonBorderStyle = formData.button_border_style || "solid";
            const buttonBorderWidth = (buttonBorderStyle && buttonBorderStyle !== "none") ? "2.5px" : "0px";

            btnDiv.innerHTML = `
              <a href="${formData.cta_link}" target="_blank" style="
                display: inline-block;
                background-color: ${formData.button_background_color || '#55c521'};
                color: ${formData.button_text_color || '#ffffff'};
                text-decoration: none;
                border-radius: 6px;
                font-size: var(--b-btn-font);
                padding: var(--b-btn-px);
                border: ${buttonBorderWidth} ${buttonBorderStyle} ${formData.button_border_color || '#9dfc1f'};
                cursor: pointer;
              ">${formData.cta_text || "Shop now"}</a>
            `;
            innerDiv.appendChild(btnDiv);
          }
        } 
        else if (formData.announcement_type === "multiple" && items.length > 1) {
          const arrowColor = formData.arrow_icon_color || "#3c9eff";
          const leftArrow = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 2.5rem; height: 2.5rem;"><polyline points="15 18 9 12 15 6"></polyline></svg>`;
          const rightArrow = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 2.5rem; height: 2.5rem;"><polyline points="9 18 15 12 9 6"></polyline></svg>`;

          const leftBtn = document.createElement("button");
          leftBtn.innerHTML = leftArrow;
          leftBtn.classList.add('ecs-nav-btn');
          leftBtn.style.cssText = `
            color: ${arrowColor}; z-index: 10; position: absolute; left: -4px;
            padding: 4px; flex-shrink: 0; background: none; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
          `;

          const rightBtn = document.createElement("button");
          rightBtn.innerHTML = rightArrow;
          rightBtn.classList.add('ecs-nav-btn');
          rightBtn.style.cssText = `
            color: ${arrowColor}; z-index: 10; position: absolute; right: -4px;
            padding: 4px; flex-shrink: 0; background: none; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
          `;

          const sliderWrapper = document.createElement("div");
          sliderWrapper.style.cssText = `flex-grow: 1; display: flex; align-items: center; overflow: hidden; width: 100%; height: 100%; position: relative;`;

          // Build extended list: [dup-last, item0, item1, ..., itemN, dup-first]
          let extendedItems = [items[items.length - 1]];
          for (let _k = 0; _k < items.length; _k++) { extendedItems[_k + 1] = items[_k]; }
          extendedItems[items.length + 1] = items[0];
          let totalSlides = extendedItems.length; // items.length + 2

          const sliderTrack = document.createElement("div");
          // Track is totalSlides*100% wide; each slide is (100/totalSlides)% of track.
          // Initial transform is set HERE (element not yet painted) so no animation fires
          // on first paint, but transition is kept active for all subsequent moves.
          // flex-shrink:0 prevents the flex parent from collapsing the track.
          sliderTrack.style.cssText = `
            display: flex; width: ${totalSlides * 100}%; height: 100%;
            flex-shrink: 0;
            transform: translateX(-${(1 / totalSlides) * 100}%);
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
          `;

          let trackHtml = '';
          for (let _k2 = 0; _k2 < extendedItems.length; _k2++) {
            trackHtml += `<div style="width: ${100 / totalSlides}%; flex-shrink: 0; display: flex; justify-content: center; align-items: center; padding-top: 1px; padding-bottom: 1px;">
              ${createAnnouncementContent(formData, extendedItems[_k2])}
            </div>`;
          }
          sliderTrack.innerHTML = trackHtml;

          let currentIndex = 1;    // 1-based: 1..items.length are the real slides
          let isSliding   = false; // blocks user input during the animation window
          let boundaryTimer = null;
          let autoplayTimer = null;

          // ── helpers ────────────────────────────────────────────────────

          // Animated slide — transition is always active so cubic easing always plays
          let slideTo = function(idx) {
            let pct = (idx / totalSlides) * 100;
            sliderTrack.style.transform = 'translateX(-' + pct + '%)';
          };

          // Instant snap (no animation) for invisible boundary recycling
          let snapTo = function(idx) {
            sliderTrack.style.transition = 'none';
            let pct = (idx / totalSlides) * 100;
            sliderTrack.style.transform = 'translateX(-' + pct + '%)';
            sliderTrack.offsetHeight; // force reflow so transition:none frame is committed
            sliderTrack.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
          };

          // ── boundary cycling ─────────────────────────────────────────────
          let scheduleBoundarySnap = function() {
            isSliding = true;
            clearTimeout(boundaryTimer);
            boundaryTimer = setTimeout(function() {
              boundaryTimer = null;
              if (currentIndex <= 0) {
                currentIndex = items.length;
              } else {
                currentIndex = 1;
              }
              snapTo(currentIndex);
              requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                  isSliding = false;
                });
              });
            }, 500);
          };

          // ── autoplay (setTimeout so each slide always gets a full 3 s) ─────────
          let resetAutoplay = function() {
            clearTimeout(autoplayTimer);
            autoplayTimer = setTimeout(function() {
              if (!isSliding) {
                handleNext();
              } else {
                resetAutoplay(); // still sliding — retry in another 3s
              }
            }, 4000); 
          };

          // ── public handlers ──────────────────────────────────────────────
          let handleNext = function() {
            if (isSliding) return;
            isSliding = true;
            resetAutoplay(); // every navigation resets the 3-s countdown
            currentIndex++;
            slideTo(currentIndex);
            if (currentIndex > items.length) {
              scheduleBoundarySnap();
            } else {
              setTimeout(function() { isSliding = false; }, 520);
            }
          };

          let handlePrev = function() {
            if (isSliding) return;
            isSliding = true;
            resetAutoplay(); // every navigation resets the 3-s countdown
            currentIndex--;
            slideTo(currentIndex);
            if (currentIndex <= 0) {
              scheduleBoundarySnap();
            } else {
              setTimeout(function() { isSliding = false; }, 520);
            }
          };

          rightBtn.onclick = handleNext;
          leftBtn.onclick  = handlePrev;

          // kick off the first autoplay tick
          resetAutoplay();

          sliderWrapper.appendChild(sliderTrack);
          contentBox.appendChild(leftBtn);
          contentBox.appendChild(sliderWrapper);
          contentBox.appendChild(rightBtn);
          innerDiv.appendChild(contentBox);
        } else {
          const annDiv = document.createElement("div");
          annDiv.style.cssText = `width: 100%; display: flex; justify-content: center; align-items: center; flex-shrink:1; min-width: 0; transition: all 0.3s ease;`;
          annDiv.innerHTML = createAnnouncementContent(formData, items[0]);
          contentBox.appendChild(annDiv);
          innerDiv.appendChild(contentBox);
        }
        
        outerDiv.appendChild(innerDiv);
        return outerDiv;
      };

      fetch(apiUrl)
        .then(res => res.json())
        .then(res => {
          if(!res.success || !res.data) return;
          const announcements = res.data.filter(a => a.enabled && shouldDisplayOnPage(a.page_display));
          if(announcements.length === 0) return;
          
          announcements.forEach((formData, index) => {
            const barDom = createBarDOM(formData, index);
            topContainer.appendChild(barDom);
          });

          const hasStickyAnnouncement = announcements.some(a => a.sticky_bar === true);
          if (hasStickyAnnouncement && topContainer.children.length > 0) {
            topContainer.classList.add('ecs-sticky-top-{{ block.id }}');
          }
        })
        .catch(err => console.error('ECS Announcement Error:', err));
    })();
  </script>
{% endif %}

